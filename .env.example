# Base URL of the application under test
BASE_URL=http://localhost:3100

# Browser to run tests in: chromium | firefox | webkit
# Leave blank to run all three browsers in parallel
BROWSER=chromium

# Run browsers in headless mode: true | false
HEADLESS=true

# Mobile device emulation: true | false
IS_MOBILE=false

# Playwright device name (only used when IS_MOBILE=true)
# To list all available device names, run:
# node -e "const { devices } = require('@playwright/test'); console.log(Object.keys(devices).join('\n'))"
# Examples: "iPhone 13", "Pixel 7", "Galaxy S8", "iPad (gen 7)"
DEVICE=iPhone 13

# Target OS platform label (used in project/report naming)
# Options: windows | macos | linux
PLATFORM=linux
