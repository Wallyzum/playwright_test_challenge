{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "playwright.config.ts",
    "utils/**/*.ts",
    "pages/**/*.ts",
    "fixtures/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "test-results"]
}
